t: 9px; bottom: -5px; left: calc(50% - 4px); transform: rotate(45deg); back=
ground: rgb(0, 0, 0); border-top-left-radius: 10px; z-index: -1; border-rig=
ht: 1px solid; border-bottom: 1px solid; }

